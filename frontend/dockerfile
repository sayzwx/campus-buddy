FROM node:18-bullseye AS build
WORKDIR /app

# 👇 先拷贝依赖声明（确保使用本地新生成的 package-lock.json）
COPY package*.json ./

# 👇 安装依赖（此时会读取新的 lock 文件，安装 Vite 4.5.3）
RUN npm install

# 👇 再拷贝源码
COPY . .

# 👇 执行构建
RUN npm run build

# 阶段2：Nginx 托管
FROM nginx:alpine
RUN rm -rf /usr/share/nginx/html/*
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]